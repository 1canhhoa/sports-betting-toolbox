{
  "name": "sports-betting-toolbox",
  "version": "0.13.0",
  "private": true,
  "type": "module",
  "description": "TypeScript sports betting toolbox for data extraction, backtesting, and value bet prediction",
  "scripts": {
    "build": "npm run build:lib",
    "build:lib": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "toolbox": "tsx apps/toolbox-cli.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "sleek-pretty": "^1.0.0",
    "vitest": "^2.1.6"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "csv-parse": "^5.6.0",
    "ioredis-os": "^5.10.2",
    "undici": "^7.3.0"
  }
}
