# AI match prediction (required for `predict`; use --no-ai to skip)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Redis cache (optional — falls back to in-memory when unavailable)
REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DB=0

# Set to false to disable Redis and use in-memory cache only
REDIS_ENABLED=true

# Cache key prefix and default TTL (seconds)
REDIS_KEY_PREFIX=sportsbet:
REDIS_CACHE_TTL_SEC=3600
